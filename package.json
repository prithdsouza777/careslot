{
  "name": "mediconnect",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "build": "cd frontend && npm run build",
    "seed": "npm run seed --workspace backend",
    "install:all": "npm install --workspaces"
  },
  "dependencies": {
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
